# InkedN — environment variables (example)
#
# This static project does NOT require a build step or env loader to run.
# These variables are provided as a convention for any future tooling
# (e.g. a tiny Node script that templates `firebase-config.js` from env).
#
# Copy this file to `.env` and fill in your own values. Do NOT commit `.env`.

FIREBASE_API_KEY=YOUR_API_KEY
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com
FIREBASE_PROJECT_ID=your-project
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=0000000000
FIREBASE_APP_ID=1:0000000000:web:xxxxxxxxxxxxxxxx
FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
